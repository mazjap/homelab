# Secrets and sensitive data
.env
*.env
.env.*
!.env.example

# Service data directories (contain runtime data, databases, logs)
pihole/
unbound/
wg-easy/
gitea/
uptime-kuma/
portainer/
nginx-proxy-manager/
glances/
linkding/
paperless/

# Homepage - Keep configs, ignore runtime data
homepage/logs/
